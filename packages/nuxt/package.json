{
  "name": "nuxt-compose-icons",
  "version": "0.6.7",
  "private": false,
  "scripts": {
    "dev": "PORT=3008 nuxi dev playground",
    "dev:build": "nuxi build playground",
    "dev:generate": "nuxi generate playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepack": "nuxt-module-build build",
    "test": "vitest run --coverage",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit",
    "test:unit": "vitest run --project unit",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@nuxt/kit": "4.4.2",
    "@use-compose/logger": "0.0.6",
    "lightningcss": "1.32.0",
    "node-html-parser": "7.1.0",
    "svg-parser": "2.0.4",
    "svgo": "4.0.1"
  },
  "devDependencies": {
    "@nuxt/devtools": "3.2.4",
    "@nuxt/eslint-config": "1.15.2",
    "@nuxt/module-builder": "1.0.2",
    "@nuxt/schema": "4.4.2",
    "@nuxt/test-utils": "4.0.0",
    "@types/node": "latest",
    "@types/svg-parser": "2.0.6",
    "@vitest/coverage-v8": "4.1.2",
    "@vitest/ui": "4.1.2",
    "changelogen": "0.6.2",
    "eslint": "9.39.4",
    "nuxt": "4.4.2",
    "playwright-core": "1.58.2",
    "typescript": "6.0.2",
    "vitest": "4.1.2",
    "vue-tsc": "3.2.6"
  },
  "exports": {
    ".": {
      "types": "./dist/module.d.mts",
      "import": "./dist/module.mjs"
    },
    "./utils": {
      "types": "./dist/runtime/utils/index.d.ts",
      "import": "./dist/runtime/utils/index.js"
    },
    "./types": {
      "types": "./dist/runtime/types/index.d.ts",
      "import": "./dist/runtime/types/index.js"
    },
    "./composables": {
      "types": "./dist/runtime/composables/index.d.ts",
      "import": "./dist/runtime/composables/index.js"
    },
    "./components": {
      "types": "./dist/runtime/components/*.d.ts",
      "import": "./dist/runtime/components/*.js"
    },
    "./registry": {
      "types": "./dist/runtime/registry/index.d.ts",
      "import": "./dist/runtime/registry/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**"
  ],
  "license": "MIT",
  "main": "./dist/module.mjs",
  "module": "./dist/module.mjs",
  "packageManager": "pnpm@10.33.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/arthur-plazanet/nuxt-compose-icons"
  },
  "type": "module",
  "types": "./dist/module.d.mts"
}
